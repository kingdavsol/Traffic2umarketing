# ============================================
# NODE & ENVIRONMENT
# ============================================
NODE_ENV="production"
NODE_OPTIONS="--max-old-space-size=2048"

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://traffic2u_user:strong_password@localhost:5432/traffic2u"
DATABASE_POOL_SIZE="20"
DATABASE_SSL="true"

# ============================================
# NEXT.JS CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_URL="https://petcovercompare.com"
NEXT_PUBLIC_API_URL="https://petcovercompare.com/api"
NEXT_PUBLIC_SITE_NAME="Pet Cover Compare"

# ============================================
# EMAIL SERVICE (RESEND)
# ============================================
RESEND_API_KEY="re_your_actual_key_here"
RESEND_FROM_EMAIL="noreply@traffic2umarketing.com"

# ============================================
# AFFILIATE TRACKING
# ============================================
ENABLE_AFFILIATE_TRACKING="true"
AFFILIATE_COOKIE_DURATION="30"

# ============================================
# API SECURITY & RATE LIMITING
# ============================================
API_RATE_LIMIT_REQUESTS="100"
API_RATE_LIMIT_WINDOW_MS="900000"
API_QUOTE_CACHE_TTL="86400"

# ============================================
# CORS (FOR API ENDPOINTS)
# ============================================
CORS_ORIGINS="https://petcovercompare.com,https://disabilityquotehub.com,https://cybersmallbizcompare.com,https://travelinsurancecompare.io,https://umbrellainsurancequotes.com,https://motorcycleinsurancehub.com,https://sr22insurancequick.com,https://weddinginsurancecompare.com,https://droneinsurancecompare.io,https://landlordinsurancecompare.com"

# ============================================
# SECURITY
# ============================================
JWT_SECRET="change-me-to-random-32-character-string"
ENCRYPTION_KEY="change-me-to-random-32-character-string"

# ============================================
# ANALYTICS & MONITORING
# ============================================
NEXT_PUBLIC_GTAG_ID=""
SENTRY_DSN=""
LOG_LEVEL="info"
ENABLE_ANALYTICS="true"

# ============================================
# CARRIER AFFILIATE APIs (Optional for future)
# ============================================
TRUPANION_API_KEY=""
FETCH_API_KEY=""
HISCOX_API_KEY=""

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_EMAIL_VERIFICATION="true"
ENABLE_AFFILIATE_TRACKING="true"
ENABLE_ANALYTICS="true"
ENABLE_RATE_LIMITING="true"
ENABLE_CORS="true"
