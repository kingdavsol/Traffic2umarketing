# ==========================================
# CAR MAINTENANCE HUB - ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to .env and fill in your actual values
# Never commit .env file to version control

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL="postgresql://user:password@localhost:5432/car_maintenance_hub"

# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000

# ==========================================
# JWT / AUTHENTICATION
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ==========================================
# STRIPE CONFIGURATION
# ==========================================
# Get these from https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Price IDs for subscription tiers (from Stripe)
STRIPE_PRICE_PRO=price_pro_monthly_id
STRIPE_PRICE_BUSINESS=price_business_monthly_id

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
# Using Gmail App Password (recommended)
# See: https://support.google.com/accounts/answer/185833
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Alternative: Using SendGrid
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=your-sendgrid-api-key

# Email settings
EMAIL_FROM_NAME="Car Maintenance Hub"
EMAIL_FROM_ADDRESS=noreply@carmaintenancehub.com

# ==========================================
# AFFILIATE CONFIGURATION
# ==========================================
# Amazon Associates
AMAZON_ASSOCIATE_ID=your-amazon-associate-id
AMAZON_ASSOCIATE_TAG=yourtag-20

# eBay Partner Network
EBAY_PARTNER_ID=your-ebay-partner-id
EBAY_CAMPAIGN_ID=your-ebay-campaign-id

# RockAuto Affiliate
ROCKAUTO_AFFILIATE_ID=your-rockauto-affiliate-id

# PartsGeek Affiliate
PARTSGEEK_AFFILIATE_ID=your-partsgeek-affiliate-id

# ==========================================
# EXTERNAL APIs
# ==========================================
# NHTSA API (Vehicle data - no key required)
NHTSA_API_BASE=https://vpic.nhtsa.dot.gov/api

# RockAuto API (if available)
ROCKAUTO_API_KEY=your-rockauto-api-key

# ==========================================
# CACHING CONFIGURATION
# ==========================================
# TTL in seconds
CACHE_VEHICLE_SPECS_TTL=604800  # 7 days
CACHE_PRICES_TTL=86400          # 1 day
CACHE_PROBLEMS_TTL=604800       # 7 days

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100     # per window

# ==========================================
# PRICE ALERT CONFIGURATION
# ==========================================
# How often to check for price drops (in minutes)
PRICE_ALERT_CHECK_INTERVAL=60

# Minimum price difference to trigger alert (in cents)
PRICE_ALERT_MIN_DROP=100        # $1.00

# ==========================================
# ADMIN CONFIGURATION
# ==========================================
# Admin email addresses (comma separated)
ADMIN_EMAILS=admin@carmaintenancehub.com,moderator@carmaintenancehub.com

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
# Options: error, warn, info, debug

# ==========================================
# FEATURES
# ==========================================
# Enable/disable features
FEATURE_AFFILIATE_LINKS=true
FEATURE_PRICE_ALERTS=true
FEATURE_USER_GUIDES=true
FEATURE_SUBSCRIPTIONS=true
FEATURE_ADMIN_DASHBOARD=true

# ==========================================
# ANALYTICS
# ==========================================
# Google Analytics
GOOGLE_ANALYTICS_ID=

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ==========================================
# THIRD-PARTY SERVICES (Optional)
# ==========================================
# Twilio SMS (for SMS alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS S3 (for guide images/videos)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ==========================================
# PAYMENT WEBHOOK
# ==========================================
# Stripe webhook signing secret (same as STRIPE_WEBHOOK_SECRET)
WEBHOOK_SECRET=your-webhook-secret-same-as-stripe-webhook-secret
