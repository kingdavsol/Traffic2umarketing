{
  "expo": {
    "name": "QuickSell",
    "slug": "quicksell",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "owner": "markd98",
    "extra": {
      "eas": {
        "projectId": "bf85a847-ef74-4f1a-a9fc-60e81c961bd9"
      }
    },
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#007AFF",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quicksell.app"
    },
    "android": {
      "package": "com.quicksell.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#007AFF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "QuickSell needs camera access to photograph items for sale."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "QuickSell needs photo access to select item photos.",
          "cameraPermission": "QuickSell needs camera access to photograph items."
        }
      ]
    ]
  }
}
